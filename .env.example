# ─── Database ─────────────────────────────────────────────────────────────────
# Adapter: sqlite (default) | turso | postgres | mysql | d1
DB_ADAPTER=sqlite

# SQLite — local file (default for dev)
DATABASE_URL=./local.db

# Turso (libSQL) — https://turso.tech
# DB_ADAPTER=turso
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# Postgres — Supabase / Neon / Vercel Postgres
# DB_ADAPTER=postgres
# DATABASE_URL=postgresql://user:password@host:5432/database

# MySQL — PlanetScale / Railway / Render
# DB_ADAPTER=mysql
# DATABASE_URL=mysql://user:password@host:3306/database

# Cloudflare D1 — requires Cloudflare Pages deployment (see docs/adapters/d1.md)
# DB_ADAPTER=d1
# D1_DB_NAME=DB

# ─── Auth ─────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:3000

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_DOMAIN=localhost:3000
COOKIE_DOMAIN=localhost

# ─── AI / MCP (v0.6) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Google Workspace MCP (gmail, google-calendar, drive)
# See docs/mcp.md for setup instructions
GOOGLE_MCP_URL=
GOOGLE_MCP_TOKEN=

# Notion MCP — https://www.notion.so/profile/integrations
NOTION_MCP_TOKEN=
